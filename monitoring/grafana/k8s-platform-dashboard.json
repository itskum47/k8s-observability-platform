{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_available{namespace=~\"observability-.*\"})",
          "refId": "A"
        }
      ],
      "title": "Available Replicas",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"observability-.*\",container!=\"\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=~\"observability-.*\",resource=\"cpu\"})",
          "refId": "A"
        }
      ],
      "title": "CPU Utilization",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"observability-.*\",container!=\"\"})",
          "refId": "A"
        }
      ],
      "title": "Memory Working Set",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"observability-.*\"}[1h]))",
          "refId": "A"
        }
      ],
      "title": "Pod Restarts (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(backend_http_requests_total{namespace=~\"observability-.*\"}[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Backend Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 6,
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"observability-.*\"}",
          "legendFormat": "{{horizontalpodautoscaler}}",
          "refId": "A"
        }
      ],
      "title": "HPA Current Replicas",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "kubernetes",
    "platform",
    "observability"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "K8s Observability Platform",
  "version": 1
}
